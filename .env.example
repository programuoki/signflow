# Copy to .env for local development. `go run` loads it automatically.

# Postgres connection string (pgx/libpq format).
DATABASE_URL=postgres://postgres@localhost:5432/signflow?sslmode=disable

# HTTP port. Railway sets this for you in production.
PORT=8080

# "dev" or "prod". prod requires SESSION_SECRET and BASE_URL and sets Secure cookies.
APP_ENV=dev

# Public origin used to build links in emails. Defaults to http://localhost:PORT in dev.
# BASE_URL=https://signflow.up.railway.app

# Secret used to authenticate session cookies. REQUIRED in prod.
# Generate: openssl rand -base64 32
# SESSION_SECRET=

# Email provider. "console" (default in dev) prints links to the terminal.
# Set to "resend" and provide RESEND_API_KEY to send real email in prod.
EMAIL_SENDER=console
# RESEND_API_KEY=
# EMAIL_FROM=SignFlow <no-reply@yourdomain.com>
